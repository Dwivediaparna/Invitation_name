# NEXT_PUBLIC_GEMINI_API_KEY: Required for Gemini AI image generation.
# This MUST be prefixed with NEXT_PUBLIC_ so Next.js embeds it in the client bundle at build time.
# Get your key at: https://aistudio.google.com/apikey
NEXT_PUBLIC_GEMINI_API_KEY="your_gemini_api_key_here"

# APP_URL: The URL where this applet is hosted (optional).
APP_URL="http://localhost:3000"
